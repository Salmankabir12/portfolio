---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { sanityClient } from '../../lib/sanity'
import { getPostBySlugQuery } from '../../lib/queries'
import { PortableText } from '@portabletext/react'

const { slug } = Astro.params

const post = await sanityClient.fetch(getPostBySlugQuery, { slug })

if (!post) {
  throw new Error('Post not found')
}
---

<BaseLayout title={post.title}>
  <article class="max-w-3xl mx-auto py-10">
    <h1 class="text-3xl font-bold mb-2">{post.title}</h1>
    <p class="text-sm text-(--text-muted) mb-4">
      {new Date(post.publishedAt).toLocaleDateString()}
    </p>

    {post.tags && (
      <div class="flex gap-2 flex-wrap mb-6">
        {post.tags.map((tag: string) => (
          <span class="text-xs bg-(--tag) text-(--tag-text) px-2 py-1 rounded">{tag}</span>
        ))}
      </div>
    )}

    <div class="prose prose-invert">
      <PortableText value={post.body} />
    </div>
  </article>
</BaseLayout>
