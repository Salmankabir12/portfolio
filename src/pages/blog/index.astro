---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { sanityClient } from '../../lib/sanity'
import { getAllPostsQuery } from '../../lib/queries'
import type { Post } from '../../types/blog'

const posts = await sanityClient.fetch(getAllPostsQuery)
---

<BaseLayout title="Blog">
  <div class="max-w-5xl mx-auto py-10">
    <h1 class="text-3xl font-bold mb-6">Blog</h1>

    {posts.length === 0 ? (
      <p class="text-(--text-muted)">No posts yet. Check back soon.</p>
    ) : (
      <div class="grid md:grid-cols-2 gap-6">
        {posts.map((post: Post) => (
          <a href={`/blog/${post.slug.current}`} class="block border border-(--border) bg-(--surface-elevated) p-4 rounded-lg hover:shadow-md hover:-translate-y-0.5 transition">
            <h2 class="text-xl font-semibold mb-2">{post.title}</h2>
            <p class="text-sm text-(--text-muted) mb-2">
              {new Date(post.publishedAt).toLocaleDateString()}
            </p>
            {post.excerpt && <p class="mb-2">{post.excerpt}</p>}
            {post.tags && (
              <div class="flex gap-2 flex-wrap">
                {post.tags.map((tag: string) => (
                  <span class="text-xs bg-(--tag) text-(--tag-text) px-2 py-1 rounded">{tag}</span>
                ))}
              </div>
            )}
          </a>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
