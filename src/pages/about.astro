---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="About">
  <section class="py-16 grid md:grid-cols-2 gap-10 items-center">
    <div class="w-full h-64 md:h-80 bg-(--surface-raised) rounded-xl flex items-center justify-center text-6xl">
      👨‍💻
    </div>
    <div>
      <h1 class="text-4xl font-bold mb-4">Salman kabir</h1>
      <p class="text-(--text-muted) mb-6">
        I'm a full stack developer focused on building performant and user-friendly applications.
      </p>
      <div class="space-y-4 text-(--text-secondary)">
        <p>
          I specialize in building full-stack applications with modern web technologies, from
          architecting scalable backends to crafting polished frontend experiences.
        </p>
        <p>
          I work extensively with TypeScript, React, Node.js, and Cloudflare Workers, building
          performant applications deployed at the edge.
        </p>
        <p>
          I believe in clean architecture, type-safe code, and developer experience — both for
          myself and for teams I collaborate with.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
