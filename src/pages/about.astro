---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="About">
  <section class="py-16 grid md:grid-cols-2 gap-10 items-center">
    <div class="w-full h-64 md:h-80 bg-gray-800 rounded-xl"></div>
    <div>
      <h1 class="text-4xl font-bold mb-4">Salman kabir</h1>
      <p class="text-gray-400 mb-6">
        I'm a full stack developer focused on building performant and user-friendly applications.
      </p>
      <ul class="space-y-3 text-gray-300">
        <li class="border-b border-gray-800 pb-2">Experience 1</li>
        <li class="border-b border-gray-800 pb-2">Experience 2</li>
        <li>Experience 3</li>
      </ul>
    </div>
  </section>
</BaseLayout>
